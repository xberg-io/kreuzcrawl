{
	"name": "@kreuzberg/kreuzcrawl",
	"version": "0.1.0",
	"description": "High-performance web crawling engine",
	"license": "Elastic-2.0",
	"main": "index.js",
	"types": "index.d.ts",
	"repository": {
		"type": "git",
		"url": "https://github.com/kreuzberg-dev/kreuzcrawl.git"
	},
	"author": {
		"name": "Na'aman Hirschfeld",
		"email": "naaman@kreuzberg.dev",
		"url": "https://kreuzberg.dev"
	},
	"homepage": "https://kreuzberg.dev",
	"bugs": {
		"url": "https://github.com/kreuzberg-dev/kreuzcrawl/issues"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public"
	},
	"keywords": [
		"crawl",
		"scrape",
		"web",
		"spider",
		"rust"
	],
	"files": [
		"index.js",
		"index.d.ts",
		"**/*.node"
	],
	"scripts": {
		"build": "napi build --release",
		"build:debug": "napi build",
		"test": "node -e \"console.log('Add test command')\""
	},
	"napi": {
		"name": "kreuzcrawl",
		"triples": [
			"x86_64-unknown-linux-gnu",
			"x86_64-apple-darwin",
			"aarch64-apple-darwin",
			"x86_64-pc-windows-msvc"
		]
	},
	"devDependencies": {
		"@napi-rs/cli": "^2.0.0"
	}
}
