{
  "name": "@kreuzberg/kreuzcrawl",
  "version": "0.1.0",
  "description": "High-performance web crawling engine",
  "license": "Elastic-2.0",
  "main": "index.js",
  "types": "index.d.ts",
  "repository": "https://github.com/kreuzberg-dev/kreuzcrawl",
