    full_page: bool | None

class PageActionExecuteJsVariant(TypedDict):
    type: Literal["executeJs"]
    script: str

class PageActionScrapeVariant(TypedDict):
    type: Literal["scrape"]

class PageAction:
    type: str
    def __str__(self) -> str: ...  # noqa: PYI029
    def __repr__(self) -> str: ...  # noqa: PYI029

class ScrollDirection:
    up: ScrollDirection = ...
    down: ScrollDirection = ...
    def __init__(self, value: int | str) -> None: ...

def generate_citations(markdown: str) -> CitationResult: ...
def create_engine(config: CrawlConfig | None = None) -> CrawlEngineHandle: ...
async def scrape(engine: CrawlEngineHandle, url: str) -> ScrapeResult: ...
async def crawl(engine: CrawlEngineHandle, url: str) -> CrawlResult: ...
async def map_urls(engine: CrawlEngineHandle, url: str) -> MapResult: ...
async def interact(
    engine: CrawlEngineHandle,
    url: str,
    actions: list[PageAction],
) -> InteractionResult: ...

async def batch_scrape(engine: CrawlEngineHandle, urls: list[str]) -> BatchScrapeResults: ...
async def batch_crawl(engine: CrawlEngineHandle, urls: list[str]) -> BatchCrawlResults: ...
