MOCK_SERVER_BIN ?= ../rust/target/release/mock-server
MOCK_SERVER_MANIFEST ?= ../rust/Cargo.toml
FIXTURES_DIR ?= ../../fixtures

.PHONY: all clean test smoke

# Mock-server orchestration macro: build, spawn, setup env, run $(TEST_CMD), cleanup
define run_with_mock_server
	@if [ -n "$$MOCK_SERVER_URL" ]; then \
		if [ -n "$$MOCK_SERVERS" ]; then \
			eval $$(python3 -c "import json,os; d=json.loads(os.environ.get('MOCK_SERVERS','{}')); print(' '.join('export MOCK_SERVER_'+k.upper()+'='+v for k,v in d.items()))"); \
		fi; \
		$(TEST_CMD); \
	else \
		if [ ! -x "$(MOCK_SERVER_BIN)" ]; then \
			echo "Building mock-server from $(MOCK_SERVER_MANIFEST)..."; \
			cargo build --release --manifest-path "$(MOCK_SERVER_MANIFEST)" --bin mock-server || exit 1; \
		fi; \
		rm -f mock_server.stdout mock_server.stdin; \
		mkfifo mock_server.stdin; \
		"$(MOCK_SERVER_BIN)" "$(FIXTURES_DIR)" <mock_server.stdin >mock_server.stdout 2>&1 & \
		MOCK_PID=$$!; \
		exec 9>mock_server.stdin; \
		MOCK_URL=""; MOCK_SERVERS_JSON=""; \
		for _ in $$(seq 1 100); do \
			if [ -s mock_server.stdout ]; then \
				MOCK_URL=$$(grep -o 'MOCK_SERVER_URL=[^ ]*' mock_server.stdout | head -1 | cut -d= -f2); \
				if [ -n "$$MOCK_URL" ]; then break; fi; \
			fi; \
			sleep 0.05; \
		done; \
		MOCK_SERVERS_JSON=$$(grep -o 'MOCK_SERVERS={.*}' mock_server.stdout | head -1 | cut -d= -f2-); \
		if [ -z "$$MOCK_URL" ]; then echo 'failed to start mock-server' >&2; cat mock_server.stdout >&2; kill $$MOCK_PID 2>/dev/null || true; exit 1; fi; \
		if [ -n "$$MOCK_SERVERS_JSON" ] && command -v python3 >/dev/null 2>&1; then \
			eval $$(python3 -c "import json,sys; d=json.loads(sys.argv[1]); print(' '.join('export MOCK_SERVER_{}={}'.format(k.upper(),v) for k,v in d.items()))" "$$MOCK_SERVERS_JSON"); \
		fi; \
		MOCK_SERVER_URL="$$MOCK_URL" $(TEST_CMD); STATUS=$$?; \
		exec 9>&-; \
		kill $$MOCK_PID 2>/dev/null || true; \
		rm -f mock_server.stdout mock_server.stdin; \
		exit $$STATUS; \
	fi
endef

test: $(TARGET)
	@TEST_CMD='./$(TARGET)' $(MAKE) -s run_with_mock_server

smoke: $(TARGET)
	@TEST_CMD='./$(TARGET) --smoke' $(MAKE) -s run_with_mock_server

run_with_mock_server:
	$(run_with_mock_server)

clean:
	rm -f $(TARGET) mock_server.stdout mock_server.stdin
