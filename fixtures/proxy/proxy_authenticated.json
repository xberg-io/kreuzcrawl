{
	"id": "proxy_authenticated",
	"description": "Proxy with username and password credentials authenticates successfully",
	"tags": ["proxy", "auth"],
	"skip": {
		"languages": ["wasm", "homebrew"],
		"reason": "Proxy configuration not supported in WASM or Homebrew environments"
	},
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Authenticated Proxy</h1><p>Proxy auth succeeded</p></body></html>"
			}
		],
		"config": {
			"proxy": {
				"url": "http://127.0.0.1:8889",
				"username": "proxyuser",
				"password": "proxypass"
			},
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "status_code",
			"value": 200
		},
		{
			"type": "equals",
			"field": "pages.length",
			"value": 1
		}
	]
}
