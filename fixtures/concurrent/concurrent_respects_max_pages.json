{
	"id": "concurrent_respects_max_pages",
	"description": "Concurrent crawling respects max_pages limit",
	"tags": [
		"concurrent"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><a href=\"/p1\">1</a><a href=\"/p2\">2</a><a href=\"/p3\">3</a><a href=\"/p4\">4</a></body></html>"
			},
			{
				"path": "/p1",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>Page 1</h1></body></html>"
			},
			{
				"path": "/p2",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>Page 2</h1></body></html>"
			},
			{
				"path": "/p3",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>Page 3</h1></body></html>"
			},
			{
				"path": "/p4",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>Page 4</h1></body></html>"
			}
		],
		"config": {
			"max_depth": 1,
			"max_pages": 3,
			"max_concurrent": 2
		}
	},
	"assertions": [
		{
			"type": "less_than_or_equal",
			"field": "pages.length",
			"value": 3
		}
	]
}
