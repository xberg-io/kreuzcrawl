{
  "id": "concurrent_basic",
  "description": "Concurrent crawling fetches all pages with max_concurrent workers",
  "tags": ["concurrent"],
  "mock_responses": [
    {
      "path": "/",
      "headers": {"content-type": "text/html"},
      "body_inline": "<html><body><a href=\"/p1\">1</a><a href=\"/p2\">2</a><a href=\"/p3\">3</a><a href=\"/p4\">4</a><a href=\"/p5\">5</a></body></html>"
    },
    {
      "path": "/p1",
      "headers": {"content-type": "text/html"},
      "body_inline": "<html><body><h1>Page 1</h1></body></html>"
    },
    {
      "path": "/p2",
      "headers": {"content-type": "text/html"},
      "body_inline": "<html><body><h1>Page 2</h1></body></html>"
    },
    {
      "path": "/p3",
      "headers": {"content-type": "text/html"},
      "body_inline": "<html><body><h1>Page 3</h1></body></html>"
    },
    {
      "path": "/p4",
      "headers": {"content-type": "text/html"},
      "body_inline": "<html><body><h1>Page 4</h1></body></html>"
    },
    {
      "path": "/p5",
      "headers": {"content-type": "text/html"},
      "body_inline": "<html><body><h1>Page 5</h1></body></html>"
    }
  ],
  "config": {
    "engine_mode": true,
    "max_depth": 1,
    "max_concurrent": 3
  },
  "assertions": {
    "crawl": {
      "pages_crawled": 6,
      "min_pages": 6
    }
  }
}
