{
  "id": "middleware_engine_crawl_with_defaults",
  "description": "Engine crawl with default middleware chain produces correct multi-page results",
  "tags": ["middleware", "crawl"],
  "mock_responses": [
    {
      "path": "/",
      "headers": {"content-type": "text/html"},
      "body_inline": "<html><body><a href=\"/page1\">P1</a><a href=\"/page2\">P2</a></body></html>"
    },
    {
      "path": "/page1",
      "headers": {"content-type": "text/html"},
      "body_inline": "<html><head><title>Page 1</title></head><body><h1>Page 1</h1></body></html>"
    },
    {
      "path": "/page2",
      "headers": {"content-type": "text/html"},
      "body_inline": "<html><head><title>Page 2</title></head><body><h1>Page 2</h1></body></html>"
    }
  ],
  "config": {
    "engine_mode": true,
    "max_depth": 1
  },
  "assertions": {
    "crawl": {
      "pages_crawled": 3,
      "min_pages": 3
    }
  }
}
