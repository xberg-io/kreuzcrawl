{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "kreuzcrawl E2E Fixture (Alef format)",
	"description": "Defines a single end-to-end crawl/scrape scenario with mock HTTP responses in the Alef fixture format.",
	"type": "object",
	"required": ["id", "description", "assertions"],
	"properties": {
		"id": {
			"type": "string",
			"pattern": "^[a-z0-9_]+$",
			"description": "Unique identifier used as test function name."
		},
		"description": {
			"type": "string"
		},
		"tags": {
			"type": "array",
			"items": { "type": "string" }
		},
		"skip": {
			"type": "object",
			"properties": {
				"languages": {
					"type": "array",
					"items": { "type": "string" },
					"description": "Language bindings to skip this test for."
				},
				"reason": {
					"type": "string",
					"description": "Human-readable explanation for why this test is skipped."
				}
			}
		},
		"input": {
			"type": "object",
			"properties": {
				"mock_responses": {
					"type": "array",
					"items": {
						"type": "object",
						"properties": {
							"path": { "type": "string" },
							"method": { "type": "string", "default": "GET" },
							"status_code": { "type": "integer" },
							"headers": { "type": "object", "additionalProperties": { "type": "string" } },
							"body_file": { "type": "string", "description": "Path relative to fixtures/responses/" },
							"body_inline": { "type": "string", "description": "Inline response body (alternative to body_file)" }
						}
					},
					"description": "Mock HTTP responses for the test scenario."
				},
				"batch_urls": {
					"type": "array",
					"items": { "type": "string" },
					"description": "List of URLs/paths to batch-scrape (not part of CrawlConfig)"
				},
				"rate_limit_delay_ms": {
					"type": "integer",
					"minimum": 0,
					"description": "Delay between requests in milliseconds (not part of CrawlConfig)"
				},
				"crawl_strategy": {
					"type": "string",
					"enum": ["bfs", "dfs", "best_first", "adaptive"],
					"description": "Crawl traversal strategy (not part of CrawlConfig)"
				},
				"content_filter": {
					"type": "string",
					"description": "Content filter type (e.g. 'bm25', 'none') (not part of CrawlConfig)"
				},
				"bm25_query": {
					"type": "string",
					"description": "BM25 query string for content filtering (not part of CrawlConfig)"
				},
				"bm25_threshold": {
					"type": "number",
					"description": "BM25 score threshold for content filtering (not part of CrawlConfig)"
				},
				"config": {
					"type": "object",
					"properties": {
						"max_depth": { "type": "integer", "minimum": 0 },
						"max_pages": { "type": "integer", "minimum": 1 },
						"respect_robots_txt": { "type": "boolean" },
						"request_timeout": { "type": "integer", "minimum": 0, "description": "Request timeout in milliseconds" },
						"user_agent": { "type": "string" },
						"stay_on_domain": { "type": "boolean" },
						"include_paths": {
							"type": "array",
							"items": { "type": "string" },
							"description": "Regex patterns for URLs to include"
						},
						"exclude_paths": {
							"type": "array",
							"items": { "type": "string" },
							"description": "Regex patterns for URLs to exclude"
						},
						"allow_subdomains": { "type": "boolean" },
						"max_redirects": { "type": "integer", "minimum": 0 },
						"max_body_size": { "type": "integer", "minimum": 0, "description": "Max body size in bytes" },
						"max_concurrent": { "type": "integer", "minimum": 1 },
						"custom_headers": { "type": "object", "additionalProperties": { "type": "string" } },
						"cookies_enabled": { "type": "boolean" },
						"auth": {
							"type": "object",
							"description": "Authentication config — one of basic, bearer, or header",
							"properties": {
								"basic": {
									"type": "object",
									"required": ["username", "password"],
									"properties": {
										"username": { "type": "string" },
										"password": { "type": "string" }
									}
								},
								"bearer": {
									"type": "object",
									"required": ["token"],
									"properties": {
										"token": { "type": "string" }
									}
								},
								"header": {
									"type": "object",
									"required": ["name", "value"],
									"properties": {
										"name": { "type": "string" },
										"value": { "type": "string" }
									}
								}
							}
						},
						"retry_count": { "type": "integer", "minimum": 0 },
						"retry_codes": { "type": "array", "items": { "type": "integer" } },
						"remove_tags": {
							"type": "array",
							"items": { "type": "string" },
							"description": "CSS selectors for elements to remove"
						},
						"content": { "type": "object", "description": "Content extraction configuration" },
						"map_search": { "type": "string", "description": "Search keyword filter for map results" },
						"map_limit": { "type": "integer", "minimum": 1, "description": "Limit number of map results" },
						"browser": {
							"type": "object",
							"description": "Browser config for headless rendering",
							"properties": {
								"mode": {
									"type": "string",
									"enum": ["auto", "always", "never"],
									"description": "When to use browser fallback"
								},
								"endpoint": { "type": "string", "description": "CDP WebSocket endpoint URL for external browser" },
								"timeout": { "type": "integer", "minimum": 0, "description": "Browser page load timeout in ms" },
								"wait": {
									"type": "string",
									"enum": ["network_idle", "selector", "fixed"],
									"description": "Wait strategy after navigation"
								},
								"wait_selector": {
									"type": "string",
									"description": "CSS selector to wait for when wait is selector"
								},
								"extra_wait": {
									"type": "integer",
									"minimum": 0,
									"description": "Extra wait time after wait condition in ms"
								}
							}
						},
						"user_agents": { "type": "array", "items": { "type": "string" } },
						"proxy": {
							"type": "object",
							"properties": {
								"url": { "type": "string" }
							}
						},
						"download_documents": { "type": "boolean", "description": "Enable document downloading (PDF, etc.)" },
						"document_mime_types": {
							"type": "array",
							"items": { "type": "string" },
							"description": "Allowlist of MIME types to download"
						},
						"document_max_size": { "type": "integer", "minimum": 0, "description": "Max document size in bytes" },
						"warc_output": { "type": "string", "description": "Path to write WARC output file" },
						"browser_profile": { "type": "string", "description": "Named browser profile for persistent sessions" },
						"save_browser_profile": { "type": "boolean", "description": "Save changes back to browser profile" }
					}
				},
				"actions": {
					"type": "array",
					"items": { "type": "object" },
					"description": "Page interaction actions (Click, Type, Scroll, Wait, ExecuteJs, etc.)"
				},
				"batch_mode": {
					"type": "string",
					"enum": ["scrape", "crawl"],
					"description": "Whether batch operation is scrape or crawl (default: scrape)"
				}
			}
		},
		"assertions": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["type"],
				"properties": {
					"type": {
						"type": "string",
						"enum": [
							"equals",
							"contains",
							"not_empty",
							"greater_than_or_equal",
							"less_than_or_equal",
							"greater_than",
							"less_than",
							"contains_all",
							"is_empty",
							"not_contains",
							"error"
						],
						"description": "Assertion type."
					},
					"field": {
						"type": "string",
						"description": "Dot-separated field path for the assertion target."
					},
					"value": {
						"description": "Expected value. For 'error' type without value, indicates any error. For 'error' with value, indicates specific error type."
					}
				}
			},
			"description": "Flat array of assertions to verify test outcomes."
		}
	},
	"additionalProperties": false
}
