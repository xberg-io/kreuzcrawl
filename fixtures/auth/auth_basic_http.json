{
	"id": "auth_basic_http",
	"description": "Sends HTTP Basic authentication header",
	"tags": [
		"auth",
		"basic"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Authenticated Page</h1></body></html>"
			}
		],
		"config": {
			"auth": {
				"type": "basic",
				"username": "testuser",
				"password": "testpass"
			},
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "auth_header_sent",
			"value": true
		},
		{
			"type": "equals",
			"field": "status_code",
			"value": 200
		}
	]
}
