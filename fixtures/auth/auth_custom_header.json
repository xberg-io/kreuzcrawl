{
	"id": "auth_custom_header",
	"description": "Sends authentication via custom header (X-API-Key)",
	"tags": [
		"auth",
		"api-key"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>API Key Auth Page</h1></body></html>"
			}
		],
		"config": {
			"auth": {
				"type": "header",
				"name": "X-API-Key",
				"value": "sk-test-key-12345"
			},
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "auth_header_sent",
			"value": true
		},
		{
			"type": "equals",
			"field": "status_code",
			"value": 200
		}
	]
}
