{
	"id": "cookies_persistence",
	"description": "Maintains cookies across multiple crawl requests",
	"tags": [
		"cookies",
		"session"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"method": "GET",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8",
					"set-cookie": "session=abc123; Path=/"
				},
				"body_inline": "<html><body><a href=\"/page2\">Page 2</a></body></html>"
			},
			{
				"path": "/page2",
				"method": "GET",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Page 2</h1></body></html>"
			}
		],
		"config": {
			"max_depth": 1,
			"cookies_enabled": true,
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "contains",
			"field": "cookies",
			"value": "session"
		}
	]
}
