{
	"id": "filter_bm25_crawl_integration",
	"description": "BM25 filter works during multi-page crawl, keeping relevant pages",
	"tags": [
		"filter",
		"crawl",
		"bm25"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><p>Welcome to our rust programming guide</p><a href=\"/rust\">Rust</a><a href=\"/cooking\">Cooking</a></body></html>"
			},
			{
				"path": "/rust",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><p>Rust is a systems programming language. Rust provides memory safety.</p></body></html>"
			},
			{
				"path": "/cooking",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><p>Today we make pasta with tomato sauce and garlic.</p></body></html>"
			}
		],
		"content_filter": "bm25",
		"bm25_query": "rust programming",
		"bm25_threshold": 0.1,
		"config": {
			"max_depth": 1,
			"max_concurrent": 1
		}
	},
	"assertions": [
		{
			"type": "contains",
			"field": "filter.remaining_contain_keyword",
			"value": "rust"
		}
	]
}
