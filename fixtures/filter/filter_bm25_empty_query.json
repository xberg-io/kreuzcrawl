{
  "id": "filter_bm25_empty_query",
  "description": "BM25 filter with empty query passes all pages through",
  "tags": ["filter", "bm25"],
  "mock_responses": [
    {
      "path": "/",
      "headers": {"content-type": "text/html"},
      "body_inline": "<html><body><a href=\"/p1\">P1</a></body></html>"
    },
    {
      "path": "/p1",
      "headers": {"content-type": "text/html"},
      "body_inline": "<html><body><p>Any content here</p></body></html>"
    }
  ],
  "config": {
    "max_depth": 1,
    "content_filter": "bm25",
    "bm25_query": "",
    "bm25_threshold": 0.1
  },
  "assertions": {
    "crawl": {
      "pages_crawled": 2
    }
  }
}
