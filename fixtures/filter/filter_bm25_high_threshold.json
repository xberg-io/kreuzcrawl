{
  "id": "filter_bm25_high_threshold",
  "description": "BM25 filter with very high threshold filters out all pages",
  "tags": ["filter", "bm25"],
  "mock_responses": [
    {
      "path": "/",
      "headers": {"content-type": "text/html"},
      "body_inline": "<html><body><p>Some content about rust</p><a href=\"/page1\">Link</a></body></html>"
    },
    {
      "path": "/page1",
      "headers": {"content-type": "text/html"},
      "body_inline": "<html><body><p>More content about programming</p></body></html>"
    }
  ],
  "config": {
    "max_depth": 1,
    "content_filter": "bm25",
    "bm25_query": "quantum physics",
    "bm25_threshold": 100.0
  },
  "assertions": {
    "filter": {
      "pages_after_filter": 0
    }
  }
}
