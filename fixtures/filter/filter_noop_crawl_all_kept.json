{
	"id": "filter_noop_crawl_all_kept",
	"description": "NoopFilter keeps all pages during a multi-page crawl",
	"tags": [
		"filter",
		"crawl",
		"noop"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><a href=\"/alpha\">Alpha</a><a href=\"/beta\">Beta</a></body></html>"
			},
			{
				"path": "/alpha",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><p>Alpha page content</p></body></html>"
			},
			{
				"path": "/beta",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><p>Beta page content</p></body></html>"
			}
		],
		"content_filter": "none",
		"config": {
			"max_depth": 1,
			"max_concurrent": 1
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "filter.pages_after_filter",
			"value": 3
		}
	]
}
