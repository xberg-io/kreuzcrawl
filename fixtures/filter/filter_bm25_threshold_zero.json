{
	"id": "filter_bm25_threshold_zero",
	"description": "BM25 filter with zero threshold passes all pages",
	"tags": [
		"filter",
		"bm25"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><p>Random content</p><a href=\"/page1\">Link</a></body></html>"
			},
			{
				"path": "/page1",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><p>More random stuff</p></body></html>"
			}
		],
		"content_filter": "bm25",
		"bm25_query": "unrelated query",
		"bm25_threshold": 0.0,
		"config": {
			"max_depth": 1
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "crawl.pages_crawled",
			"value": 2
		}
	]
}
