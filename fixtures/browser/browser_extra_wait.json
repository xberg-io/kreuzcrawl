{
	"id": "browser_extra_wait",
	"description": "Browser extra_wait adds additional time after network_idle to ensure all async operations complete",
	"tags": ["browser", "wait", "network_idle", "extra_wait"],
	"skip": {
		"languages": ["wasm", "homebrew"],
		"reason": "Requires browser feature"
	},
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<!DOCTYPE html><html><head><title>Extra Wait Test</title></head><body><div><h1>Network Idle Page</h1><p>This page waits for network idle plus extra time for async operations.</p></div></body></html>"
			}
		],
		"config": {
			"browser": {
				"mode": "always",
				"wait": "network_idle",
				"extra_wait": 200
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "browser.browser_used",
			"value": true
		}
	]
}
