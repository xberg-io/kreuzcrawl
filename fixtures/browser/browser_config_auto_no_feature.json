{
	"id": "browser_config_auto_no_feature",
	"description": "Browser mode 'auto' without browser feature enabled does not use browser",
	"tags": [
		"browser",
		"config"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_file": "html/spa_react_shell.html"
			}
		],
		"config": {
			"browser": {
				"mode": "auto"
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "status_code",
			"value": 200
		},
		{
			"type": "equals",
			"field": "browser.js_render_hint",
			"value": true
		},
		{
			"type": "equals",
			"field": "browser.browser_used",
			"value": false
		}
	]
}
