{
	"id": "browser_detect_next_empty",
	"description": "Detects Next.js page with __NEXT_DATA__ but no rendered content as needing JS rendering",
	"tags": ["browser", "detection"],
	"input": {
		"config": {
			"browser": {
				"mode": "never"
			}
		},
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_file": "html/spa_next_empty.html"
			}
		]
	},
	"assertions": [
		{
			"type": "equals",
			"field": "status_code",
			"value": 200
		},
		{
			"type": "equals",
			"field": "js_render_hint",
			"value": true
		},
		{
			"type": "equals",
			"field": "browser_used",
			"value": false
		}
	]
}
