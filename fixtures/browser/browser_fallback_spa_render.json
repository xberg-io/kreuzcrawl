{
	"id": "browser_fallback_spa_render",
	"description": "Browser auto re-fetches SPA shell when JS rendering is detected",
	"tags": [
		"browser",
		"fallback",
		"spa"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_file": "html/spa_react_shell.html"
			}
		],
		"config": {
			"browser": {
				"mode": "auto"
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "browser.js_render_hint",
			"value": true
		},
		{
			"type": "equals",
			"field": "browser.browser_used",
			"value": true
		}
	]
}
