{
	"id": "browser_crawl_mode_always",
	"description": "Crawl with browser mode 'always' follows links using browser rendering",
	"tags": ["browser", "crawl"],
	"skip": {
		"languages": ["wasm", "homebrew"],
		"reason": "Browser rendering not available in WASM; homebrew lacks headless browser"
	},
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Home</h1><a href=\"/page1\">Page 1</a><a href=\"/page2\">Page 2</a></body></html>"
			},
			{
				"path": "/page1",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Page 1</h1><p>Content rendered via browser</p></body></html>"
			},
			{
				"path": "/page2",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Page 2</h1><p>Another page rendered via browser</p></body></html>"
			}
		],
		"config": {
			"max_depth": 1,
			"browser": {
				"mode": "always"
			},
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "greater_than_or_equal",
			"field": "pages.length",
			"value": 2
		},
		{
			"type": "equals",
			"field": "browser.browser_used",
			"value": true
		}
	]
}
