{
	"id": "browser_mode_always",
	"description": "Browser mode 'always' uses browser even for normal server-rendered pages",
	"tags": [
		"browser",
		"config"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_file": "html/basic_page.html"
			}
		],
		"config": {
			"browser": {
				"mode": "always"
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "browser.browser_used",
			"value": true
		}
	]
}
