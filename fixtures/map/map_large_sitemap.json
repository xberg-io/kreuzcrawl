{
	"id": "map_large_sitemap",
	"description": "Handles large sitemap with 100+ URLs",
	"tags": [
		"map",
		"sitemap",
		"large"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "application/xml"
				},
				"body_file": "xml/sitemap_large.xml"
			}
		],
		"config": {
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "greater_than_or_equal",
			"field": "urls.length",
			"value": 100
		}
	]
}
