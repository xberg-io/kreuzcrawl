{
	"id": "map_discover_urls",
	"description": "Discovers all URLs on a site without fetching full content",
	"tags": [
		"map",
		"discovery"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><a href=\"/about\">About</a><a href=\"/blog\">Blog</a><a href=\"/contact\">Contact</a></body></html>"
			}
		],
		"config": {
			"max_depth": 0,
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "greater_than_or_equal",
			"field": "urls.length",
			"value": 3
		}
	]
}
