{
	"id": "interact_screenshot_full_page",
	"description": "Screenshot full page and verify image data",
	"tags": ["interaction", "screenshot"],
	"skip": {
		"languages": ["wasm", "homebrew"],
		"reason": "Requires browser feature"
	},
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><head><title>Full Page Screenshot Test</title></head><body><h1>Header</h1><div style=\"height: 2000px;\">Long content</div><h2>Footer</h2></body></html>"
			}
		],
		"config": {
			"browser": {
				"mode": "always"
			}
		},
		"actions": [
			{
				"type": "screenshot",
				"full_page": true
			}
		]
	},
	"assertions": [
		{
			"type": "equals",
			"field": "interaction.action_results[0].success",
			"value": true
		},
		{
			"type": "equals",
			"field": "interaction.action_results[0].action_type",
			"value": "screenshot"
		},
		{
			"type": "is_true",
			"field": "interaction.action_results[0].data"
		}
	]
}
