{
	"id": "interact_screenshot",
	"description": "Screenshot a specific element via selector and verify image data",
	"tags": ["interaction", "screenshot"],
	"skip": {
		"languages": ["wasm", "homebrew"],
		"reason": "Requires browser feature"
	},
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><head><title>Screenshot Test</title></head><body><div id=\"target\" style=\"width: 200px; height: 100px; background: blue; color: white; padding: 10px;\">Screenshot me</div></body></html>"
			}
		],
		"config": {
			"browser": {
				"mode": "always"
			}
		},
		"actions": [
			{
				"type": "screenshot",
				"full_page": false
			}
		]
	},
	"assertions": [
		{
			"type": "equals",
			"field": "interaction.action_results[0].success",
			"value": true
		},
		{
			"type": "equals",
			"field": "interaction.action_results[0].action_type",
			"value": "screenshot"
		},
		{
			"type": "is_true",
			"field": "interaction.action_results[0].data"
		}
	]
}
