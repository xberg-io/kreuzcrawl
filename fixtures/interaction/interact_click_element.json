{
	"id": "interact_click_element",
	"description": "Click a button element and verify success",
	"tags": ["interaction", "click"],
	"skip": {
		"languages": ["wasm", "homebrew"],
		"reason": "Requires browser feature"
	},
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><head><title>Click Test</title></head><body><button id=\"submit\">Submit</button></body></html>"
			}
		],
		"config": {
			"browser": {
				"mode": "always"
			}
		},
		"actions": [
			{
				"type": "click",
				"selector": "#submit"
			}
		]
	},
	"assertions": [
		{
			"type": "equals",
			"field": "interaction.action_results[0].success",
			"value": true
		},
		{
			"type": "equals",
			"field": "interaction.action_results[0].action_type",
			"value": "click"
		},
		{
			"type": "equals",
			"field": "interaction.action_results[0].action_index",
			"value": 0
		}
	]
}
