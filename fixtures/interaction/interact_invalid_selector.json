{
	"id": "interact_invalid_selector",
	"description": "Click on a non-existent selector and verify error in action_results",
	"tags": ["interaction", "error"],
	"skip": {
		"languages": ["wasm", "homebrew"],
		"reason": "Requires browser feature"
	},
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><head><title>Invalid Selector Test</title></head><body><h1>Page Content</h1></body></html>"
			}
		],
		"config": {
			"browser": {
				"mode": "always"
			}
		},
		"actions": [
			{
				"type": "click",
				"selector": "#nonexistent"
			}
		]
	},
	"assertions": [
		{
			"type": "equals",
			"field": "interaction.action_results[0].success",
			"value": false
		},
		{
			"type": "equals",
			"field": "interaction.action_results[0].action_type",
			"value": "click"
		},
		{
			"type": "contains",
			"field": "interaction.action_results[0].error",
			"value": "not found"
		}
	]
}
