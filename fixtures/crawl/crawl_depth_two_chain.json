{
	"id": "crawl_depth_two_chain",
	"description": "Depth=2 crawl follows a chain of links across three levels",
	"tags": [
		"crawl",
		"depth"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><a href=\"/level1\">Level 1</a></body></html>"
			},
			{
				"path": "/level1",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><a href=\"/level2\">Level 2</a></body></html>"
			},
			{
				"path": "/level2",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>Deepest Page</h1></body></html>"
			}
		],
		"config": {
			"max_depth": 2,
			"max_concurrent": 1
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "pages.length",
			"value": 3
		}
	]
}
