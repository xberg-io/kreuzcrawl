{
	"id": "crawl_multiple_redirects_in_traversal",
	"description": "Multiple linked pages with redirects are handled during crawl traversal",
	"tags": [
		"crawl",
		"redirect"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><a href=\"/old-a\">A</a><a href=\"/old-b\">B</a></body></html>"
			},
			{
				"path": "/old-a",
				"status_code": 302,
				"headers": {
					"location": "/new-a",
					"content-type": "text/html"
				},
				"body_inline": ""
			},
			{
				"path": "/new-a",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>New A</h1></body></html>"
			},
			{
				"path": "/old-b",
				"status_code": 301,
				"headers": {
					"location": "/new-b",
					"content-type": "text/html"
				},
				"body_inline": ""
			},
			{
				"path": "/new-b",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>New B</h1></body></html>"
			}
		],
		"config": {
			"max_depth": 1,
			"max_concurrent": 1
		}
	},
	"assertions": [
		{
			"type": "greater_than_or_equal",
			"field": "pages.length",
			"value": 1
		}
	]
}
