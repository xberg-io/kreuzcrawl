{
	"id": "crawl_fragment_stripping",
	"description": "Strips #fragment from URLs for deduplication",
	"tags": [
		"crawl",
		"normalization"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"method": "GET",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><a href=\"/article\">Article</a><a href=\"/article#section1\">Section 1</a><a href=\"/article#section2\">Section 2</a></body></html>"
			},
			{
				"path": "/article",
				"method": "GET",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Article</h1></body></html>"
			}
		],
		"config": {
			"max_depth": 1,
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "unique_urls.length",
			"value": 2
		}
	]
}
