{
	"id": "crawl_max_depth_zero",
	"description": "max_depth=0 crawls only the seed page with no link following",
	"tags": [
		"crawl",
		"depth"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><a href=\"/page1\">Link</a></body></html>"
			},
			{
				"path": "/page1",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>Should not be crawled</h1></body></html>"
			}
		],
		"config": {
			"max_depth": 0
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "pages.length",
			"value": 1
		},
		{
			"type": "less_than_or_equal",
			"field": "pages.length",
			"value": 1
		}
	]
}
