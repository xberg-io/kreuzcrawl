{
	"id": "crawl_redirect_in_traversal",
	"description": "Links that redirect are followed during crawl traversal",
	"tags": [
		"crawl",
		"redirect"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><a href=\"/old\">Link</a></body></html>"
			},
			{
				"path": "/old",
				"status_code": 301,
				"headers": {
					"location": "/new",
					"content-type": "text/html"
				},
				"body_inline": ""
			},
			{
				"path": "/new",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>New Page</h1></body></html>"
			}
		],
		"config": {
			"max_depth": 1,
			"max_concurrent": 1
		}
	},
	"assertions": [
		{
			"type": "greater_than_or_equal",
			"field": "pages.length",
			"value": 1
		}
	]
}
