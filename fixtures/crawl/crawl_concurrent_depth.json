{
	"id": "crawl_concurrent_depth",
	"description": "Concurrent crawl respects max_depth limit",
	"tags": [
		"crawl",
		"concurrency"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><a href=\"/a\">A</a><a href=\"/b\">B</a></body></html>"
			},
			{
				"path": "/a",
				"status_code": 200,
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>A</h1><a href=\"/a/deep\">Deep A</a></body></html>"
			},
			{
				"path": "/b",
				"status_code": 200,
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>B</h1><a href=\"/b/deep\">Deep B</a></body></html>"
			},
			{
				"path": "/a/deep",
				"status_code": 200,
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>Deep A</h1></body></html>"
			},
			{
				"path": "/b/deep",
				"status_code": 200,
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>Deep B</h1></body></html>"
			}
		],
		"config": {
			"max_depth": 1,
			"max_concurrent": 3,
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "pages.length",
			"value": 3
		},
		{
			"type": "equals",
			"field": "stayed_on_domain",
			"value": true
		}
	]
}
