{
	"id": "crawl_mixed_content_types",
	"description": "Crawl handles links to non-HTML content types gracefully",
	"tags": [
		"crawl",
		"content"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><a href=\"/page\">Page</a><a href=\"/image.png\">Image</a></body></html>"
			},
			{
				"path": "/page",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>Normal Page</h1></body></html>"
			},
			{
				"path": "/image.png",
				"headers": {
					"content-type": "image/png"
				},
				"body_inline": "fake-png-data"
			}
		],
		"config": {
			"max_depth": 1,
			"max_concurrent": 1
		}
	},
	"assertions": [
		{
			"type": "greater_than_or_equal",
			"field": "pages.length",
			"value": 2
		}
	]
}
