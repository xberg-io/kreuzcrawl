{
	"id": "crawl_single_page_no_links",
	"description": "Crawling a page with no links returns only the seed page",
	"tags": [
		"crawl"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><p>No links here</p></body></html>"
			}
		],
		"config": {
			"max_depth": 2
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "pages.length",
			"value": 1
		}
	]
}
