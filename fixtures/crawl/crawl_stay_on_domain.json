{
	"id": "crawl_stay_on_domain",
	"description": "Does not follow external links when stay_on_domain is true",
	"tags": [
		"crawl"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><a href=\"/internal\">Internal</a><a href=\"https://external.com/page\">External</a></body></html>"
			},
			{
				"path": "/internal",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Internal Page</h1></body></html>"
			}
		],
		"config": {
			"max_depth": 1,
			"stay_on_domain": true,
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "pages.length",
			"value": 2
		},
		{
			"type": "equals",
			"field": "stayed_on_domain",
			"value": true
		}
	]
}
