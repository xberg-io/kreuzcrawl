{
	"id": "metadata_keywords_author",
	"description": "Extracts keywords, author, viewport, generator, theme-color, robots, lang, dir metadata",
	"tags": [
		"metadata"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_file": "html/comprehensive_metadata.html"
			}
		]
	},
	"assertions": [
		{
			"type": "equals",
			"field": "status_code",
			"value": 200
		},
		{
			"type": "equals",
			"field": "metadata.title",
			"value": "Comprehensive Metadata Test Page"
		},
		{
			"type": "not_empty",
			"field": "metadata.canonical_url"
		},
		{
			"type": "not_empty",
			"field": "metadata.keywords"
		},
		{
			"type": "contains",
			"field": "metadata.keywords",
			"value": "rust"
		},
		{
			"type": "equals",
			"field": "metadata.author",
			"value": "Jane Developer"
		},
		{
			"type": "not_empty",
			"field": "metadata.viewport"
		},
		{
			"type": "equals",
			"field": "metadata.generator",
			"value": "kreuzcrawl/1.0"
		},
		{
			"type": "equals",
			"field": "metadata.theme_color",
			"value": "#ff6600"
		},
		{
			"type": "equals",
			"field": "metadata.robots",
			"value": "index, follow"
		},
		{
			"type": "equals",
			"field": "metadata.lang",
			"value": "en"
		},
		{
			"type": "equals",
			"field": "metadata.dir",
			"value": "ltr"
		}
	]
}
