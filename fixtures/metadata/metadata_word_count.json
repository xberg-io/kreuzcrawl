{
	"id": "metadata_word_count",
	"description": "Computes word count from visible page text",
	"tags": [
		"metadata"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_file": "html/comprehensive_metadata.html"
			}
		]
	},
	"assertions": [
		{
			"type": "equals",
			"field": "status_code",
			"value": 200
		},
		{
			"type": "greater_than",
			"field": "computed.word_count",
			"value": 99
		},
		{
			"type": "less_than",
			"field": "computed.word_count",
			"value": 301
		}
	]
}
