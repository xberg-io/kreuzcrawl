{
	"id": "metadata_og_video_audio",
	"description": "Extracts og:video, og:audio, and og:locale:alternate metadata",
	"tags": [
		"metadata"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_file": "html/comprehensive_metadata.html"
			}
		]
	},
	"assertions": [
		{
			"type": "equals",
			"field": "status_code",
			"value": 200
		},
		{
			"type": "equals",
			"field": "og.video",
			"value": "https://example.com/video.mp4"
		},
		{
			"type": "equals",
			"field": "og.audio",
			"value": "https://example.com/audio.mp3"
		},
		{
			"type": "equals",
			"field": "og.locale_alternate.length",
			"value": 2
		}
	]
}
