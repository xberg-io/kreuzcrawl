{
	"id": "content_binary_skip",
	"description": "Skips image and video content types gracefully",
	"category": "crawl",
	"tags": [
		"content",
		"binary"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"method": "GET",
				"status_code": 200,
				"headers": {
					"content-type": "image/jpeg"
				},
				"body_inline": ""
			},
			{
				"path": "/image.jpg",
				"method": "GET",
				"status_code": 200,
				"headers": {
					"content-type": "image/jpeg"
				},
				"body_inline": ""
			},
			{
				"path": "/video.mp4",
				"method": "GET",
				"status_code": 200,
				"headers": {
					"content-type": "video/mp4"
				},
				"body_inline": ""
			}
		],
		"config": {
			"max_depth": 1,
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "content.was_skipped",
			"value": true
		}
	]
}
