{
	"id": "content_charset_iso8859",
	"description": "Handles ISO-8859-1 encoded page correctly",
	"tags": [
		"content",
		"charset"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=iso-8859-1"
				},
				"body_file": "html/charset_iso8859.html"
			}
		],
		"config": {
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "content.detected_charset",
			"value": "iso-8859-1"
		}
	]
}
