{
	"id": "content_utf8_bom",
	"description": "Handles UTF-8 content with BOM marker correctly",
	"tags": [
		"content",
		"charset"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_file": "html/utf8_bom.html"
			}
		],
		"config": {
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "content.detected_charset",
			"value": "utf-8"
		},
		{
			"type": "not_empty",
			"field": "html"
		}
	]
}
