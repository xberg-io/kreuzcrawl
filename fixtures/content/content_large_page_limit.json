{
	"id": "content_large_page_limit",
	"description": "Respects max body size limit and truncates or skips oversized pages",
	"tags": [
		"content",
		"limits"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_file": "html/large_page.html"
			}
		],
		"config": {
			"max_body_size": 1024,
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "less_than",
			"field": "content.body_size",
			"value": 1025
		}
	]
}
