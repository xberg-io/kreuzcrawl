{
	"id": "content_pdf_link_skip",
	"description": "Encounters PDF link and skips or marks as document type",
	"category": "crawl",
	"tags": [
		"content",
		"pdf"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"method": "GET",
				"status_code": 200,
				"headers": {
					"content-type": "application/pdf"
				},
				"body_inline": ""
			},
			{
				"path": "/doc.pdf",
				"method": "GET",
				"status_code": 200,
				"headers": {
					"content-type": "application/pdf"
				},
				"body_inline": ""
			},
			{
				"path": "/page",
				"method": "GET",
				"status_code": 200,
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>Page</h1></body></html>"
			}
		],
		"config": {
			"max_depth": 1,
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "content.was_skipped",
			"value": true
		}
	]
}
