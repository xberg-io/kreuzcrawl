{
	"id": "redirect_loop",
	"description": "Detects redirect loop (A -> B -> A) and returns error",
	"tags": [
		"redirect",
		"error"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Redirect Root</h1></body></html>"
			},
			{
				"path": "/a",
				"method": "GET",
				"status_code": 302,
				"headers": {
					"location": "/b"
				},
				"body_inline": ""
			},
			{
				"path": "/b",
				"method": "GET",
				"status_code": 302,
				"headers": {
					"location": "/a"
				},
				"body_inline": ""
			}
		],
		"config": {
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "is_error",
			"value": true
		}
	]
}
