{
	"id": "redirect_cross_domain",
	"description": "Reports cross-domain redirect target without following to external domain",
	"tags": [
		"redirect"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"method": "GET",
				"status_code": 302,
				"headers": {
					"location": "/external-redirect"
				},
				"body_inline": ""
			},
			{
				"path": "/external-redirect",
				"method": "GET",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Simulated external redirect target</h1></body></html>"
			}
		],
		"config": {
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "contains",
			"field": "final_url",
			"value": "/external-redirect"
		},
		{
			"type": "equals",
			"field": "redirect_count",
			"value": 1
		}
	]
}
