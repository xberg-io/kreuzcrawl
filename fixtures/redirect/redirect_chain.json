{
	"id": "redirect_chain",
	"description": "Follows a chain of redirects (301 -> 302 -> 200)",
	"tags": [
		"redirect"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"method": "GET",
				"status_code": 301,
				"headers": {
					"location": "/step1"
				},
				"body_inline": ""
			},
			{
				"path": "/step1",
				"method": "GET",
				"status_code": 302,
				"headers": {
					"location": "/step2"
				},
				"body_inline": ""
			},
			{
				"path": "/step2",
				"method": "GET",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Final Destination</h1></body></html>"
			}
		],
		"config": {
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "contains",
			"field": "final_url",
			"value": "/step2"
		},
		{
			"type": "equals",
			"field": "redirect_count",
			"value": 2
		}
	]
}
