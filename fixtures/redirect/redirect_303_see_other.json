{
	"id": "redirect_303_see_other",
	"description": "Follows 303 See Other redirect (method changes to GET)",
	"tags": [
		"redirect"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"method": "GET",
				"status_code": 303,
				"headers": {
					"location": "/see-other"
				},
				"body_inline": ""
			},
			{
				"path": "/see-other",
				"method": "GET",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>See Other</h1></body></html>"
			}
		],
		"config": {
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "contains",
			"field": "final_url",
			"value": "/see-other"
		},
		{
			"type": "equals",
			"field": "redirect_count",
			"value": 1
		}
	]
}
