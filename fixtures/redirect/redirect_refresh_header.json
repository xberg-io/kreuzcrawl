{
	"id": "redirect_refresh_header",
	"description": "Handles HTTP Refresh header redirect",
	"tags": [
		"redirect"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"method": "GET",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8",
					"refresh": "0;url=/refreshed"
				},
				"body_inline": "<html><body><p>Redirecting...</p></body></html>"
			},
			{
				"path": "/refreshed",
				"method": "GET",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Refreshed Page</h1></body></html>"
			}
		],
		"config": {
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "contains",
			"field": "final_url",
			"value": "/refreshed"
		},
		{
			"type": "equals",
			"field": "redirect_count",
			"value": 1
		}
	]
}
