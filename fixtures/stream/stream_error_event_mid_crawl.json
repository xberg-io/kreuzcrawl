{
	"id": "stream_error_event_mid_crawl",
	"description": "Stream emits error event when a page fails mid-crawl, but other pages succeed",
	"tags": ["stream", "error", "mid-crawl"],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><a href=\"/success1\">Success 1</a><a href=\"/fail\">Fail</a><a href=\"/success2\">Success 2</a></body></html>"
			},
			{
				"path": "/success1",
				"status_code": 200,
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>Success Page 1</h1></body></html>"
			},
			{
				"path": "/fail",
				"status_code": 500,
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body>Internal Server Error</body></html>"
			},
			{
				"path": "/success2",
				"status_code": 200,
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>Success Page 2</h1></body></html>"
			}
		],
		"config": {
			"max_depth": 1,
			"max_concurrent": 1,
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "stream.has_page_event",
			"value": true
		},
		{
			"type": "equals",
			"field": "stream.has_error_event",
			"value": true
		},
		{
			"type": "equals",
			"field": "stream.has_complete_event",
			"value": true
		}
	]
}
