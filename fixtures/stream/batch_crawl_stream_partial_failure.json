{
	"id": "batch_crawl_stream_partial_failure",
	"description": "Batch crawl stream emits both Page and Error events for mixed success/failure URLs",
	"tags": ["stream", "batch", "error"],
	"input": {
		"mock_responses": [
			{
				"path": "/success1",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Success 1</h1></body></html>"
			},
			{
				"path": "/success2",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Success 2</h1></body></html>"
			},
			{
				"path": "/fail",
				"status_code": 500,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body>Internal Server Error</body></html>"
			}
		],
		"config": {
			"max_concurrent": 1
		},
		"urls": [
			"__BASE__/success1",
			"__BASE__/fail",
			"__BASE__/success2"
		]
	},
	"assertions": [
		{
			"type": "is_true",
			"field": "stream.has_page_event"
		},
		{
			"type": "is_true",
			"field": "stream.has_error_event"
		},
		{
			"type": "is_true",
			"field": "stream.has_complete_event"
		}
	]
}
