{
	"id": "stream_with_error_event",
	"description": "Stream emits page and complete events even when some pages fail",
	"tags": [
		"stream",
		"error"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><a href=\"/fail\">Fail</a></body></html>"
			},
			{
				"path": "/fail",
				"status_code": 500,
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "Error"
			}
		],
		"config": {
			"max_depth": 1,
			"max_concurrent": 1
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "stream.has_page_event",
			"value": true
		},
		{
			"type": "equals",
			"field": "stream.has_complete_event",
			"value": true
		},
		{
			"type": "greater_than_or_equal",
			"field": "stream.event_count_min",
			"value": 2
		}
	]
}
