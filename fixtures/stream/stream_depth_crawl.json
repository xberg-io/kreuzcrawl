{
	"id": "stream_depth_crawl",
	"description": "Stream produces events for multi-depth crawl with link following",
	"tags": [
		"stream",
		"depth"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><a href=\"/child1\">C1</a><a href=\"/child2\">C2</a></body></html>"
			},
			{
				"path": "/child1",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><a href=\"/grandchild\">GC</a></body></html>"
			},
			{
				"path": "/child2",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>Child 2</h1></body></html>"
			},
			{
				"path": "/grandchild",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>Grandchild</h1></body></html>"
			}
		],
		"config": {
			"max_depth": 2,
			"max_concurrent": 1
		}
	},
	"assertions": [
		{
			"type": "greater_than_or_equal",
			"field": "stream.event_count_min",
			"value": 5
		},
		{
			"type": "equals",
			"field": "stream.has_page_event",
			"value": true
		},
		{
			"type": "equals",
			"field": "stream.has_complete_event",
			"value": true
		}
	]
}
