{
  "id": "error_waf_blocked",
  "description": "WAF challenge/block detection returns WafBlocked error",
  "tags": [
    "error",
    "waf"
  ],
  "input": {
    "config": {
      "browser": {
        "mode": "never"
      }
    }
  },
  "assertions": [
    {
      "type": "error"
    },
    {
      "type": "error",
