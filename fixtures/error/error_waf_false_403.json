{
	"id": "error_waf_false_403",
	"description": "Detects WAF/bot protection false 403 (Cloudflare challenge page)",
	"tags": ["error", "waf"],
	"input": {
		"config": {
			"browser": {
				"mode": "never"
			}
		}
	},
	"assertions": [
