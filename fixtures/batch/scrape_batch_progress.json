{
	"id": "scrape_batch_progress",
	"description": "Batch scrape results include specific URL",
	"tags": [
		"batch"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Batch Root</h1></body></html>"
			},
			{
				"path": "/target",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Target Page</h1></body></html>"
			},
			{
				"path": "/other",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Other Page</h1></body></html>"
			}
		],
		"batch_urls": [
			"/target",
			"/other"
		],
		"config": {}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "batch.total_count",
			"value": 2
		},
		{
			"type": "contains",
			"field": "batch.results",
			"value": "/target"
		}
	]
}
