{
	"id": "scrape_batch_partial_failure",
	"description": "Batch scrape with one URL failing returns partial results",
	"tags": [
		"batch"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Batch Root</h1></body></html>"
			},
			{
				"path": "/good1",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Good 1</h1></body></html>"
			},
			{
				"path": "/bad",
				"status_code": 500,
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body>Error</body></html>"
			},
			{
				"path": "/good2",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Good 2</h1></body></html>"
			}
		],
		"batch_urls": [
			"/good1",
			"/bad",
			"/good2"
		],
		"config": {}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "batch.completed_count",
			"value": 2
		},
		{
			"type": "equals",
			"field": "batch.failed_count",
			"value": 1
		},
		{
			"type": "equals",
			"field": "batch.total_count",
			"value": 3
		}
	]
}
