{
	"id": "sitemap_compressed_gzip",
	"description": "Parses a gzip-compressed sitemap file",
	"tags": [
		"sitemap",
		"compression"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "application/x-gzip"
				},
				"body_file": "xml/sitemap_gzip.xml.gz"
			}
		],
		"config": {
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "urls.length",
			"value": 3
		}
	]
}
