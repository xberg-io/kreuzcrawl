{
	"id": "sitemap_xhtml_links",
	"description": "Parses sitemap with XHTML namespace alternate links",
	"tags": [
		"sitemap",
		"xhtml"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "application/xml"
				},
				"body_file": "xml/sitemap_xhtml.xml"
			}
		],
		"config": {
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "urls.length",
			"value": 2
		},
		{
			"type": "equals",
			"field": "has_lastmod",
			"value": false
		}
	]
}
