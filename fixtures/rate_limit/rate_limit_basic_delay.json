{
  "id": "rate_limit_basic_delay",
  "description": "Rate limiter adds delay between requests to the same domain",
  "tags": ["rate_limit"],
  "mock_responses": [
    {
      "path": "/",
      "headers": {"content-type": "text/html"},
      "body_inline": "<html><body><a href=\"/page1\">P1</a><a href=\"/page2\">P2</a></body></html>"
    },
    {
      "path": "/page1",
      "headers": {"content-type": "text/html"},
      "body_inline": "<html><body><h1>Page 1</h1></body></html>"
    },
    {
      "path": "/page2",
      "headers": {"content-type": "text/html"},
      "body_inline": "<html><body><h1>Page 2</h1></body></html>"
    }
  ],
  "config": {
    "max_depth": 1,
    "rate_limit_delay_ms": 100
  },
  "assertions": {
    "crawl": {
      "pages_crawled": 3
    },
    "rate_limit": {
      "min_duration_ms": 150
    }
  }
}
