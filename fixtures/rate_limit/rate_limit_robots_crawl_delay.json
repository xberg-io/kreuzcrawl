{
	"id": "rate_limit_robots_crawl_delay",
	"description": "Respects Crawl-delay directive in robots.txt",
	"tags": ["rate_limit", "robots_txt", "crawl_delay"],
	"input": {
		"mock_responses": [
			{
				"path": "/robots.txt",
				"status_code": 200,
				"headers": {
					"content-type": "text/plain"
				},
				"body_inline": "User-agent: TestBot\nCrawl-delay: 1\nDisallow:\n"
			},
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>Home</h1><a href=\"/page1\">P1</a></body></html>"
			},
			{
				"path": "/page1",
				"status_code": 200,
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>Page 1</h1></body></html>"
			}
		],
		"config": {
			"respect_robots_txt": true,
			"user_agent": "TestBot",
			"max_depth": 1
		}
	},
	"assertions": [
		{
			"type": "greater_than_or_equal",
			"field": "pages.length",
			"value": 1
		},
		{
			"type": "equals",
			"field": "status_code",
			"value": 200
		}
	]
}
