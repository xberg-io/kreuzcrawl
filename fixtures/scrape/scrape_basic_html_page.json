{
	"id": "scrape_basic_html_page",
	"description": "Scrapes a simple HTML page and extracts title, description, and links",
	"tags": [
		"scrape",
		"metadata",
		"smoke"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html"
				},
				"body_file": "html/basic_page.html"
			}
		],
		"config": {
			"max_depth": 0,
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "status_code",
			"value": 200
		},
		{
			"type": "equals",
			"field": "content_type",
			"value": "text/html"
		},
		{
			"type": "not_empty",
			"field": "html"
		},
		{
			"type": "equals",
			"field": "metadata.title",
			"value": "Example Domain"
		},
		{
			"type": "contains",
			"field": "metadata.description",
			"value": "illustrative examples"
		},
		{
			"type": "not_empty",
			"field": "metadata.canonical_url"
		},
		{
			"type": "greater_than",
			"field": "links.length",
			"value": 0
		},
		{
			"type": "contains_all",
			"field": "links[].link_type",
			"values": [
				"external"
			]
		},
		{
			"type": "equals",
			"field": "images.length",
			"value": 0
		},
		{
			"type": "is_empty",
			"field": "og.title"
		}
	]
}
