{
	"id": "scrape_asset_dedup",
	"description": "Same asset linked twice results in one download with one unique hash",
	"tags": [
		"scrape",
		"assets"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><head><meta charset=\"utf-8\"><title>Dedup Asset Test</title><link rel=\"stylesheet\" href=\"/fixtures/scrape_asset_dedup/assets/style.css\"></head><body><h1>Dedup Test</h1><img src=\"/fixtures/scrape_asset_dedup/assets/photo.jpg\" alt=\"First reference\"><img src=\"/fixtures/scrape_asset_dedup/assets/photo.jpg\" alt=\"Second reference\"></body></html>"
			},
			{
				"path": "/assets/style.css",
				"status_code": 200,
				"headers": {
					"content-type": "text/css"
				},
				"body_file": "assets/style.css"
			},
			{
				"path": "/assets/photo.jpg",
				"status_code": 200,
				"headers": {
					"content-type": "image/jpeg"
				},
				"body_file": "assets/photo.jpg"
			}
		],
		"config": {
			"download_assets": true
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "status_code",
			"value": 200
		},
		{
			"type": "equals",
			"field": "assets.length",
			"value": 2
		},
		{
			"type": "not_empty",
			"field": "assets[].content_hash"
		}
	]
}
