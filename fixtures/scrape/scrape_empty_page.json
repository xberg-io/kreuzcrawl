{
	"id": "scrape_empty_page",
	"description": "Handles an empty HTML document without errors",
	"tags": [
		"scrape",
		"edge-case"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_file": "html/empty.html"
			}
		]
	},
	"assertions": [
		{
			"type": "equals",
			"field": "status_code",
			"value": 200
		},
		{
			"type": "greater_than",
			"field": "links.length",
			"value": -1
		},
		{
			"type": "equals",
			"field": "images.length",
			"value": 0
		}
	]
}
