{
	"id": "scrape_asset_type_filter",
	"description": "Only downloads image assets when asset_types filter is set",
	"tags": [
		"scrape",
		"assets"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><head><meta charset=\"utf-8\"><title>Page With Assets</title><link rel=\"stylesheet\" href=\"/fixtures/scrape_asset_type_filter/assets/style.css\"><script src=\"/fixtures/scrape_asset_type_filter/assets/script.js\"></script></head><body><h1>Asset Test Page</h1><img src=\"/fixtures/scrape_asset_type_filter/assets/photo.jpg\" alt=\"Test photo\"></body></html>"
			},
			{
				"path": "/assets/style.css",
				"status_code": 200,
				"headers": {
					"content-type": "text/css"
				},
				"body_file": "assets/style.css"
			},
			{
				"path": "/assets/script.js",
				"status_code": 200,
				"headers": {
					"content-type": "application/javascript"
				},
				"body_file": "assets/script.js"
			},
			{
				"path": "/assets/photo.jpg",
				"status_code": 200,
				"headers": {
					"content-type": "image/jpeg"
				},
				"body_file": "assets/photo.jpg"
			}
		],
		"config": {
			"download_assets": true,
			"asset_types": [
				"image"
			]
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "status_code",
			"value": 200
		},
		{
			"type": "equals",
			"field": "assets.length",
			"value": 1
		},
		{
			"type": "contains",
			"field": "assets[].category",
			"value": "image"
		}
	]
}
