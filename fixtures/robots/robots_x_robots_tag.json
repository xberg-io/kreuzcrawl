{
	"id": "robots_x_robots_tag",
	"description": "Respects X-Robots-Tag HTTP header directives",
	"tags": [
		"robots",
		"http-header"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8",
					"x-robots-tag": "noindex, nofollow"
				},
				"body_inline": "<html><body><h1>Page with X-Robots-Tag</h1></body></html>"
			}
		],
		"config": {
			"respect_robots_txt": true
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "robots.x_robots_tag",
			"value": "noindex, nofollow"
		},
		{
			"type": "equals",
			"field": "robots.noindex_detected",
			"value": true
		},
		{
			"type": "equals",
			"field": "robots.nofollow_detected",
			"value": true
		}
	]
}
