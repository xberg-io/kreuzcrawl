{
	"id": "robots_crawl_delay",
	"description": "Respects crawl-delay directive from robots.txt",
	"tags": ["robots", "rate-limit"],
	"input": {
		"mock_responses": [
			{
				"path": "/robots.txt",
				"status_code": 200,
				"headers": {
					"content-type": "text/plain"
				},
				"body_file": "robots/crawl_delay.txt"
			},
			{
				"path": "/fixtures/robots_crawl_delay",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>robots_crawl_delay</h1></body></html>"
			}
		],
		"config": {
			"respect_robots_txt": true,
			"user_agent": "kreuzcrawl"
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "robots.crawl_delay",
			"value": 2
		}
	]
}
