{
	"id": "robots_disallow_path",
	"description": "Robots.txt disallows specific paths",
	"tags": ["robots"],
	"input": {
		"mock_responses": [
			{
				"path": "/robots.txt",
				"status_code": 200,
				"headers": {
					"content-type": "text/plain"
				},
				"body_file": "robots/disallow_admin.txt"
			},
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>robots_disallow_path</h1></body></html>"
			}
		],
		"config": {
			"respect_robots_txt": true
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "robots.is_allowed",
			"value": false
		}
	]
}
