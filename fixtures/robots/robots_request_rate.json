{
	"id": "robots_request_rate",
	"description": "Parses request-rate directive from robots.txt",
	"tags": ["robots", "rate-limit"],
	"input": {
		"mock_responses": [
			{
				"path": "/robots.txt",
				"status_code": 200,
				"headers": {
					"content-type": "text/plain"
				},
				"body_file": "robots/request_rate.txt"
			},
			{
				"path": "/fixtures/robots_request_rate",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>robots_request_rate</h1></body></html>"
			}
		],
		"config": {
			"respect_robots_txt": true,
			"user_agent": "kreuzcrawl"
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "robots.crawl_delay",
			"value": 5
		},
		{
			"type": "equals",
			"field": "robots.is_allowed",
			"value": true
		}
	]
}
