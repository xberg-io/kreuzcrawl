{
	"id": "robots_comments_handling",
	"description": "Correctly parses robots.txt with inline and line comments",
	"tags": [
		"robots",
		"parsing"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/plain"
				},
				"body_file": "robots/with_comments.txt"
			}
		],
		"config": {
			"respect_robots_txt": true,
			"user_agent": "kreuzcrawl"
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "robots.is_allowed",
			"value": true
		}
	]
}
