{
	"id": "robots_comments_handling",
	"description": "Correctly parses robots.txt with inline and line comments",
	"tags": ["robots", "parsing"],
	"input": {
		"mock_responses": [
			{
				"path": "/robots.txt",
				"status_code": 200,
				"headers": {
					"content-type": "text/plain"
				},
				"body_file": "robots/with_comments.txt"
			},
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>robots_comments_handling</h1></body></html>"
			}
		],
		"config": {
			"respect_robots_txt": true,
			"user_agent": "kreuzcrawl"
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "robots.is_allowed",
			"value": true
		}
	]
}
