{
	"id": "robots_multiple_user_agents",
	"description": "Picks the most specific user-agent block from robots.txt",
	"tags": ["robots", "user-agent"],
	"input": {
		"mock_responses": [
			{
				"path": "/robots.txt",
				"status_code": 200,
				"headers": {
					"content-type": "text/plain"
				},
				"body_file": "robots/multiple_agents.txt"
			},
			{
				"path": "/fixtures/robots_multiple_user_agents",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>robots_multiple_user_agents</h1></body></html>"
			}
		],
		"config": {
			"respect_robots_txt": true,
			"user_agent": "SpecificBot"
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "robots.is_allowed",
			"value": true
		}
	]
}
