{
	"id": "robots_sitemap_directive",
	"description": "Discovers sitemap URL from Sitemap directive in robots.txt",
	"tags": ["robots", "sitemap"],
	"input": {
		"mock_responses": [
			{
				"path": "/robots.txt",
				"status_code": 200,
				"headers": {
					"content-type": "text/plain"
				},
				"body_file": "robots/with_sitemap.txt"
			},
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>robots_sitemap_directive</h1></body></html>"
			}
		],
		"config": {
			"respect_robots_txt": true
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "robots.is_allowed",
			"value": true
		}
	]
}
