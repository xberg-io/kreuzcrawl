{
	"id": "robots_meta_noindex",
	"description": "Detects noindex meta robots tag in HTML page",
	"tags": [
		"robots",
		"meta"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_file": "html/meta_noindex.html"
			}
		],
		"config": {
			"respect_robots_txt": true
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "robots.noindex_detected",
			"value": true
		}
	]
}
