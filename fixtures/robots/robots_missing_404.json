{
	"id": "robots_missing_404",
	"description": "Missing robots.txt (404) allows all crawling",
	"tags": ["robots"],
	"input": {
		"mock_responses": [
			{
				"path": "/robots.txt",
				"status_code": 404,
				"headers": {
					"content-type": "text/plain"
				},
				"body_inline": "Not Found"
			},
			{
				"path": "/fixtures/robots_missing_404",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>robots_missing_404</h1></body></html>"
			}
		],
		"config": {
			"respect_robots_txt": true
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "robots.is_allowed",
			"value": true
		}
	]
}
