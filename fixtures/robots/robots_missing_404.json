{
	"id": "robots_missing_404",
	"description": "Missing robots.txt (404) allows all crawling",
	"tags": [
		"robots"
	],
	"input": {
		"mock_responses": [
			{
				"status_code": 404,
				"headers": {
					"content-type": "text/plain"
				},
				"body_inline": "Not Found"
			}
		],
		"config": {
			"respect_robots_txt": true
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "robots.is_allowed",
			"value": true
		}
	]
}
