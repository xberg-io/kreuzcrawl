{
	"id": "cache_miss_fresh_fetch",
	"description": "Uncached URLs are fetched fresh without conditional headers",
	"tags": ["cache", "fresh_fetch"],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>Home</h1><a href=\"/page1\">P1</a><a href=\"/page2\">P2</a></body></html>"
			},
			{
				"path": "/page1",
				"status_code": 200,
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>Page 1</h1></body></html>"
			},
			{
				"path": "/page2",
				"status_code": 200,
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><h1>Page 2</h1></body></html>"
			}
		],
		"config": {
			"max_depth": 1
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "pages.length",
			"value": 3
		},
		{
			"type": "equals",
			"field": "status_code",
			"value": 200
		}
	]
}
