{
	"id": "cache_last_modified",
	"description": "Last-Modified header enables conditional requests via If-Modified-Since",
	"tags": ["cache", "last-modified", "conditional"],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html",
					"last-modified": "Mon, 01 Jan 2024 00:00:00 GMT"
				},
				"body_inline": "<html><body><h1>Content</h1><a href=\"/page\">Link</a></body></html>"
			},
			{
				"path": "/page",
				"status_code": 200,
				"headers": {
					"content-type": "text/html",
					"last-modified": "Tue, 02 Jan 2024 12:00:00 GMT"
				},
				"body_inline": "<html><body><h1>Linked Page</h1></body></html>"
			}
		],
		"config": {
			"max_depth": 1
		}
	},
	"assertions": [
		{
			"type": "greater_than_or_equal",
			"field": "pages.length",
			"value": 1
		}
	]
}
