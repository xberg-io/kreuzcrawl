{
	"id": "engine_scrape_basic",
	"description": "CrawlEngine with defaults scrapes a page identically to the free function",
	"tags": [
		"engine",
		"scrape"
	],
	"skip": {
		"languages": [
			"wasm",
			"c"
		],
		"reason": "requires mock HTTP server"
	},
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><head><title>Engine Test</title><meta name=\"description\" content=\"Testing the engine\"></head><body><h1>Hello Engine</h1><a href=\"/page2\">Link</a></body></html>"
			}
		],
		"config": {
			"engine_mode": true
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "status_code",
			"value": 200
		},
		{
			"type": "equals",
			"field": "content_type",
			"value": "text/html"
		},
		{
			"type": "equals",
			"field": "metadata.title",
			"value": "Engine Test"
		},
		{
			"type": "contains",
			"field": "metadata.description",
			"value": "Testing the engine"
		},
		{
			"type": "greater_than_or_equal",
			"field": "links.length",
			"value": 1
		},
		{
			"type": "equals",
			"field": "headings.h1_text",
			"value": "Hello Engine"
		}
	]
}
