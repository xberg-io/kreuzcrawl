{
	"id": "engine_crawl_basic",
	"description": "CrawlEngine with defaults crawls multiple pages like the free function",
	"tags": [
		"engine",
		"crawl"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><body><a href=\"/page1\">Page 1</a><a href=\"/page2\">Page 2</a></body></html>"
			},
			{
				"path": "/page1",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><head><title>Page 1</title></head><body><h1>Page 1</h1></body></html>"
			},
			{
				"path": "/page2",
				"headers": {
					"content-type": "text/html"
				},
				"body_inline": "<html><head><title>Page 2</title></head><body><h1>Page 2</h1></body></html>"
			}
		],
		"config": {
			"max_depth": 1
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "crawl.pages_crawled",
			"value": 3
		},
		{
			"type": "greater_than_or_equal",
			"field": "crawl.min_pages",
			"value": 3
		}
	]
}
