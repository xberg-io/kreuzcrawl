{
	"id": "engine_map_basic",
	"description": "CrawlEngine with defaults discovers URLs like the free function",
	"tags": [
		"engine",
		"map"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>Map Root</h1></body></html>"
			},
			{
				"path": "/robots.txt",
				"headers": {
					"content-type": "text/plain"
				},
				"body_inline": "User-agent: *\nAllow: /\nSitemap: {{mock_uri}}/sitemap.xml"
			},
			{
				"path": "/sitemap.xml",
				"headers": {
					"content-type": "application/xml"
				},
				"body_inline": "<?xml version=\"1.0\" encoding=\"UTF-8\"?><urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\"><url><loc>{{mock_uri}}/page1</loc></url><url><loc>{{mock_uri}}/page2</loc></url></urlset>"
			}
		],
		"config": {}
	},
	"assertions": [
		{
			"type": "greater_than_or_equal",
			"field": "map.min_urls",
			"value": 2
		}
	]
}
