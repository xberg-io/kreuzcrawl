{
	"name": "kreuzberg-dev/kreuzcrawl",
	"description": "High-performance web crawling engine",
	"license": "Elastic-2.0",
	"type": "php-ext",
	"require": {
		"php": ">=8.2"
	},
	"require-dev": {
		"phpstan/phpstan": "^2.1",
		"friendsofphp/php-cs-fixer": "^3.95",
		"phpunit/phpunit": "^13.1"
	},
	"autoload": {
		"psr-4": {
			"Kreuzcrawl\\": "src/"
		}
	},
	"scripts": {
		"phpstan": "php -d detect_unicode=0 vendor/bin/phpstan --configuration=phpstan.neon --memory-limit=512M",
		"format": "php vendor/bin/php-cs-fixer fix --quiet",
		"format:check": "php vendor/bin/php-cs-fixer fix --dry-run --quiet",
		"test": "php vendor/bin/phpunit",
		"lint": "@phpstan",
		"lint:fix": "php vendor/bin/php-cs-fixer fix --quiet && php -d detect_unicode=0 vendor/bin/phpstan --configuration=phpstan.neon --memory-limit=512M"
	},
	"php-ext": {
		"extension-name": "kreuzcrawl",
		"support-zts": true,
		"support-nts": true,
		"download-url-method": "pre-packaged-binary"
	},
	"keywords": [
		"crawl",
		"scrape",
		"spider",
		"web"
	],
	"extra": {
		"pie": {
			"binary": {
				"url-template": "https://github.com/kreuzberg-dev/kreuzcrawl/releases/download/{Version}/php_kreuzcrawl-{Version}_php{PhpVersion}-{Arch}-{OSLower}-{Libc}-{TSMode}.tgz"
			}
		}
	}
}
