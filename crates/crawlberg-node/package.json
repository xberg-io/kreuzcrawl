{
  "name": "@kreuzberg/crawlberg",
  "version": "0.3.0",
  "description": "High-performance web crawling engine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xberg-io/crawlberg.git"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "files": ["index.js", "index.d.ts", "*.node"],
  "optionalDependencies": {
    "@kreuzberg/crawlberg-linux-x64-gnu": "0.3.0",
    "@kreuzberg/crawlberg-linux-arm64-gnu": "0.3.0",
    "@kreuzberg/crawlberg-linux-x64-musl": "0.3.0",
    "@kreuzberg/crawlberg-linux-arm64-musl": "0.3.0",
    "@kreuzberg/crawlberg-darwin-x64": "0.3.0",
    "@kreuzberg/crawlberg-darwin-arm64": "0.3.0",
    "@kreuzberg/crawlberg-win32-x64-msvc": "0.3.0",
    "@kreuzberg/crawlberg-win32-arm64-msvc": "0.3.0"
  },
  "napi": {
    "packageName": "@kreuzberg/crawlberg",
    "binaryName": "crawlberg-node",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "npx --yes -p @napi-rs/cli@^3.6.2 napi build --platform --release",
    "artifacts": "npx --yes -p @napi-rs/cli@^3.6.2 napi artifacts",
    "prepublishOnly": "npx --yes -p @napi-rs/cli@^3.6.2 napi prepublish -t npm --skip-optional-publish"
  },
  "engines": { "node": ">= 18" },
  "publishConfig": { "access": "public" },
  "devDependencies": { "@napi-rs/cli": "^3.6.2" }
}
