{
	"name": "@kreuzberg/kreuzcrawl",
	"version": "0.3.0-rc.53",
	"description": "High-performance web crawling engine",
	"license": "Elastic-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kreuzberg-dev/kreuzcrawl.git"
	},
	"files": [
		"index.js",
		"index.d.ts",
		"*.node"
	],
	"main": "index.js",
	"types": "index.d.ts",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"require": "./index.js",
			"default": "./index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "npx --yes -p @napi-rs/cli@^3.6.2 napi build --platform --release",
		"artifacts": "npx --yes -p @napi-rs/cli@^3.6.2 napi artifacts",
		"prepublishOnly": "npx --yes -p @napi-rs/cli@^3.6.2 napi prepublish -t npm --skip-optional-publish"
	},
	"devDependencies": {
		"@napi-rs/cli": "^3.6.2"
	},
	"optionalDependencies": {
		"@kreuzberg/kreuzcrawl-darwin-arm64": "0.3.0-rc.53",
		"@kreuzberg/kreuzcrawl-darwin-x64": "0.3.0-rc.53",
		"@kreuzberg/kreuzcrawl-linux-arm64-gnu": "0.3.0-rc.53",
		"@kreuzberg/kreuzcrawl-linux-arm64-musl": "0.3.0-rc.53",
		"@kreuzberg/kreuzcrawl-linux-x64-gnu": "0.3.0-rc.53",
		"@kreuzberg/kreuzcrawl-linux-x64-musl": "0.3.0-rc.53",
		"@kreuzberg/kreuzcrawl-win32-arm64-msvc": "0.3.0-rc.53",
		"@kreuzberg/kreuzcrawl-win32-x64-msvc": "0.3.0-rc.53"
	},
	"napi": {
		"binaryName": "kreuzcrawl-node",
		"packageName": "@kreuzberg/kreuzcrawl",
		"targets": [
			"x86_64-unknown-linux-gnu",
			"aarch64-unknown-linux-gnu",
			"x86_64-unknown-linux-musl",
			"aarch64-unknown-linux-musl",
			"x86_64-apple-darwin",
			"aarch64-apple-darwin",
			"x86_64-pc-windows-msvc",
			"aarch64-pc-windows-msvc"
		]
	},
	"engines": {
		"node": ">= 18"
	}
}
